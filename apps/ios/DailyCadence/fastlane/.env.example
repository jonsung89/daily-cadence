# Copy this file to `.env` (same directory) and fill in the real
# values. `.env` is gitignored; this `.env.example` is checked in
# as a template for the next setup.
#
# All three values come from the App Store Connect API Key you
# create at:
#   https://appstoreconnect.apple.com/access/integrations/api
#
# After generating the key, download the .p8 file ONCE — Apple
# won't let you re-download it. Save it somewhere safe; the path
# below points fastlane at it.

# The 10-character Key ID, shown next to the key name in the table.
ASC_KEY_ID=

# The Issuer ID — a UUID at the top of the Keys page. Same value
# for every key in your account.
ASC_ISSUER_ID=

# Absolute path to the .p8 file on disk. Recommended location:
#   ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
# (fastlane auto-discovers this path if you omit the variable, but
# being explicit avoids surprises.)
ASC_KEY_PATH=
