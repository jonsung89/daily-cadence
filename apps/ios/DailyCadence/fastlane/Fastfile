# Fastlane runs every command from the directory it was invoked in.
# This file is invoked from `apps/ios/DailyCadence/`, so all the
# Xcode paths below are relative to that directory.

default_platform(:ios)

platform :ios do
  desc "Bump build number, build the app, upload to TestFlight"
  lane :beta do
    # 1. Authenticate with App Store Connect via the API key.
    #    Key ID, Issuer ID, and the path to the .p8 file all come
    #    from environment variables (loaded from `fastlane/.env`,
    #    which is gitignored).
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      duration: 1200, # token lifetime in seconds; 1200 = 20 min, well within Apple's 20-min cap
      in_house: false
    )

    # 2. Bump the build number (CFBundleVersion). The marketing
    #    version (CFBundleShortVersionString — "1.0", "1.1") stays
    #    manual; bump it in Xcode's project settings when shipping
    #    a meaningful update.
    increment_build_number(xcodeproj: "DailyCadence.xcodeproj")

    # 3. Build the IPA. Uses Xcode's automatic-signing setup
    #    (the same signing you've been using via Organizer), so
    #    no provisioning-profile juggling needed.
    build_app(
      scheme: "DailyCadence",
      export_method: "app-store",
      output_directory: "build",
      output_name: "DailyCadence.ipa",
      clean: true
    )

    # 4. Upload to TestFlight. `skip_waiting_for_build_processing`
    #    returns once the upload completes — Apple's processing
    #    step (~5 min) happens server-side; you'll get an email
    #    when the build is available.
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )

    # 5. Commit the build-number bump back to git. Keeps the repo
    #    in sync with what was shipped, so the next run increments
    #    from the right baseline. Push manually when ready.
    commit_version_bump(
      xcodeproj: "DailyCadence.xcodeproj",
      message: "ci: bump build number [skip ci]",
      force: true
    )
  end

  desc "Build the app without uploading (sanity check before a real release)"
  lane :build_only do
    increment_build_number(xcodeproj: "DailyCadence.xcodeproj", skip_info_plist: false)
    build_app(
      scheme: "DailyCadence",
      export_method: "app-store",
      output_directory: "build",
      output_name: "DailyCadence.ipa",
      clean: true
    )
  end
end
