<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<!--
	Phase F.1.2.appicon — alternate-icon manifest. Required because we
	use a static Info.plist (`GENERATE_INFOPLIST_FILE = NO`); without
	this, the `ASSETCATALOG_COMPILER_ALTERNATE_APP_ICON_NAMES` build
	setting compiles the icons into the bundle but iOS can't find them
	at runtime — `setAlternateIconName(_:)` fails with "the feature is
	not supported." Each alternate's name here MUST match an
	`.appiconset` folder under `Assets.xcassets/`.
	-->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconName</key>
			<string>AppIcon</string>
		</dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<key>Blush</key>
			<dict>
				<key>CFBundleIconName</key>
				<string>Blush</string>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Blush</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Coral</key>
			<dict>
				<key>CFBundleIconName</key>
				<string>Coral</string>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Coral</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Mulberry</key>
			<dict>
				<key>CFBundleIconName</key>
				<string>Mulberry</string>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Mulberry</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Taupe</key>
			<dict>
				<key>CFBundleIconName</key>
				<string>Taupe</string>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Taupe</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Lavender</key>
			<dict>
				<key>CFBundleIconName</key>
				<string>Lavender</string>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Lavender</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Storm</key>
			<dict>
				<key>CFBundleIconName</key>
				<string>Storm</string>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Storm</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Teal</key>
			<dict>
				<key>CFBundleIconName</key>
				<string>Teal</string>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Teal</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
		</dict>
	</dict>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>DailyCadence uses the camera so you can capture a photo or video for a note without leaving the app.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DailyCadence records audio with video captures so the clip plays back with sound.</string>
	<key>SupabaseAnonKey</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>SupabaseURL</key>
	<string>$(SUPABASE_URL)</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
