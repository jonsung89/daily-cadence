<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<!--
	Phase F.1.2.appicon — alternate-icon manifest. Bundle-root file
	approach (legacy + reliable). Each alternate's CFBundleIconFiles
	entry points at a basename like "Blush"; iOS auto-resolves to
	`<basename>@2x.png` (120×120) and `<basename>@3x.png` (180×180)
	from the bundle root.

	Why NOT also CFBundleIconName + Asset Catalog alternates: tried
	both in tandem and Springboard intermittently rendered blank
	icons after a background → foreground transition (asset catalog
	and bundle-root cached states diverged). Removing the asset
	catalog alternates + the `ASSETCATALOG_COMPILER_ALTERNATE_APP_ICON_NAMES`
	build setting and committing to bundle-root files only fixed it.
	The PRIMARY icon (Sage) still goes through the asset catalog
	(needed for the App Store + auto-generated install sizes); only
	alternates use the file-based path.
	-->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconName</key>
			<string>AppIcon</string>
		</dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<!--
			Renamed from "Blush" because Springboard's icon cache on
			Jon's dev device persistently rendered "Blush" as blank
			even after multiple re-renders + app reinstalls. The cache
			lives at OS level (not app-level) so app deletion didn't
			clear it. Renaming forces Springboard to evaluate this
			alternate as a brand-new entry with no cached state.
			Functionally identical to the original Blush; just a
			different lookup key.
			-->
			<key>BlushPink</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>BlushPink</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Coral</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Coral</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Mulberry</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Mulberry</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Taupe</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Taupe</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Lavender</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Lavender</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Storm</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Storm</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Teal</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Teal</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<!--
			Plant variants (Phase F.5.planticons): hand-drawn growing
			plant rendered in each theme color, companion to the
			quote-glyph alternates above. Same bundle-root file
			convention; iOS rounds corners on display so we ship
			full-bleed squares.
			-->
			<key>PlantSage</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantSage</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
			<key>PlantBlush</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantBlush</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
			<key>PlantCoral</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantCoral</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
			<key>PlantMulberry</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantMulberry</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
			<key>PlantTaupe</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantTaupe</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
			<key>PlantLavender</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantLavender</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
			<key>PlantStorm</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantStorm</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
			<key>PlantTeal</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array><string>PlantTeal</string></array>
				<key>UIPrerenderedIcon</key><false/>
			</dict>
		</dict>
	</dict>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<!--
			OAuth callback scheme. Supabase redirects back to
			`com.jonsung.dailycadence://login-callback` after Google
			sign-in completes; ASWebAuthenticationSession listens on
			this scheme and hands the URL back to the SDK, which
			exchanges the code for a session.
			-->
			<key>CFBundleURLName</key>
			<string>com.jonsung.dailycadence.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.jonsung.dailycadence</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!--
	Encryption export compliance. App only uses Apple's standard
	HTTPS/Keychain/CryptoKit cryptography, all of which are exempt
	under the U.S. Export Administration Regulations. Setting this
	to false short-circuits the TestFlight prompt that otherwise
	appears on every upload.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>DailyCadence uses the camera so you can capture a photo or video for a note without leaving the app.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DailyCadence records audio with video captures so the clip plays back with sound.</string>
	<key>SupabaseAnonKey</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>SupabaseURL</key>
	<string>$(SUPABASE_URL)</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
